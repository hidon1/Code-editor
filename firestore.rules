rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared projects — anyone can READ (public links), only logged-in users can CREATE
    match /codesphere_shares/{shareId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Workspaces — each user can only access their own workspace (keyed by UID)
    match /codesphere_workspaces/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
